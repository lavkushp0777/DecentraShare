# DecentraShare PHP Application Configuration

# Environment
APP_ENV=development
APP_DEBUG=true

# Contract Configuration
CONTRACT_ADDRESS=0x70dD105c6D5F4be9aa803618abfCbBC5Fa1B1B82

# Web3 RPC Configuration
WEB3_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/demo

# IPFS Provider Selection (options: pinata, web3storage, custom)
IPFS_PROVIDER=pinata

# Pinata Configuration
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here

# Web3.Storage Configuration
WEB3_STORAGE_TOKEN=your_web3_storage_token_here

# Custom IPFS Node Configuration
IPFS_API_URL=https://api.ipfs.io
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# Session Configuration
SESSION_LIFETIME=86400
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true

# Application Settings
APP_NAME=DecentraShare
APP_DESCRIPTION=Decentralized file sharing using blockchain and IPFS
