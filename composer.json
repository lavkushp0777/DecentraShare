{
  "name": "decentra-share/decentra-share",
  "description": "Decentralized file sharing application using blockchain and IPFS",
  "type": "project",
  "require": {
    "php": ">=8.0",
    "guzzlehttp/guzzle": "^7.5",
    "web3p/web3.php": "^2.0",
    "symfony/dotenv": "^6.0",
    "psr/http-factory": "^1.0",
    "psr/http-client": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5"
  },
  "autoload": {
    "psr-4": {
      "DecentraShare\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000 -t public",
    "test": "phpunit"
  }
}
